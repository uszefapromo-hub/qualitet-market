# ─────────────────────────────────────────────────────────────────────────────
# Qualitet Market – Expo mobile app environment variables
#
# Copy this file to .env.local (or .env) and fill in the values for your
# environment.  Variables prefixed with EXPO_PUBLIC_ are bundled into the
# client build and visible in the app binary – never put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── API base URL ─────────────────────────────────────────────────────────────
# Choose the URL that matches your environment:
#
# Android emulator (loopback to host machine) – used as the built-in default:
#   http://10.0.2.2:5000/api
#
# iOS simulator (loopback to host machine):
#   http://localhost:5000/api
#
# Physical device / Expo Go on the same Wi-Fi network as your dev machine:
#   http://<YOUR_LAN_IP>:5000/api  (e.g. http://192.168.1.42:5000/api)
#
# Staging:
#   https://staging-api.uszefaqualitet.pl/api
#
# Production:
#   https://api.uszefaqualitet.pl/api

EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api
