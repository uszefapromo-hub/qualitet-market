# Environment variables for HurtDetalUszefaQUALITET backend
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hurtdetal_qualitet
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Platform settings
PLATFORM_MARGIN_DEFAULT=15
OWNER_EMAIL=uszefaqualitetpromo@gmail.com

# CORS – comma-separated allowed origins
ALLOWED_ORIGINS=https://uszefaqualitet.pl,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File upload
UPLOAD_MAX_SIZE_MB=10

