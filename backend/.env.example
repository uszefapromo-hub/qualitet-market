# Environment variables for HurtDetalUszefaQUALITET backend
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hurtdetal_qualitet
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
# W środowisku production ustaw długi losowy sekret (np. wygenerowany przez openssl rand -hex 32).
# Aplikacja nie uruchomi się w production z domyślną lub pustą wartością.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Platform settings
PLATFORM_MARGIN_DEFAULT=15

# Owner / admin account (used by `npm run seed:owner`)
# Run `npm run seed:owner` after first deploy to create the platform owner account.
OWNER_EMAIL=uszefaqualitetpromo@gmail.com
OWNER_PASSWORD=your-secure-password-here
OWNER_NAME=Właściciel Platformy
OWNER_PHONE=

# CORS – comma-separated allowed origins
# W production ta wartość jest wymagana i nie może być pusta.
ALLOWED_ORIGINS=https://uszefaqualitet.pl,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Auth endpoints rate limit (login + register) – raised to 30 to support
# first-100-seller onboarding campaigns without lockouts.
AUTH_RATE_LIMIT_MAX=30

# File upload
UPLOAD_MAX_SIZE_MB=10

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Obtain keys from https://dashboard.stripe.com/apikeys
# ⚠️  NEVER commit production keys (sk_live_...) to version control.
# Use sk_test_... / pk_test_... for sandbox mode, sk_live_... / pk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Webhook secret from https://dashboard.stripe.com/webhooks
# Events to listen for:
#   checkout.session.completed, checkout.session.expired
#   customer.subscription.created, customer.subscription.updated,
#   customer.subscription.deleted
#   invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ── Stripe recurring subscription Price IDs (create in Stripe Dashboard) ──────
# Each paid plan should have a corresponding recurring Price object in Stripe.
# Create monthly prices at https://dashboard.stripe.com/products and paste the
# price_XXXX IDs here.  Leave blank to fall back to one-time checkout sessions.
STRIPE_PRICE_ID_BASIC=price_your_basic_plan_price_id
STRIPE_PRICE_ID_PRO=price_your_pro_plan_price_id
STRIPE_PRICE_ID_ELITE=price_your_elite_plan_price_id
STRIPE_PRICE_ID_PREMIUM=price_your_premium_plan_price_id
STRIPE_PRICE_ID_SUPPLIER_BASIC=price_your_supplier_basic_price_id
STRIPE_PRICE_ID_SUPPLIER_PRO=price_your_supplier_pro_price_id
STRIPE_PRICE_ID_BRAND=price_your_brand_plan_price_id
STRIPE_PRICE_ID_ARTIST_PRO=price_your_artist_pro_price_id

# Payments
# HMAC-SHA256 secret used to verify incoming payment webhook callbacks.
# Leave empty to disable signature verification (not recommended for production).
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# URL of the frontend application (used for payment redirect URLs)
APP_URL=https://uszefaqualitet.pl

# Bank transfer details (shown to customers when method=transfer)
BANK_ACCOUNT_NUMBER=PL00 0000 0000 0000 0000 0000 0000

# ─── Mail / SMTP ───────────────────────────────────────────────────────────────
# Proton Mail Bridge (self-hosted): https://proton.me/mail/bridge
# For Proton Mail Bridge (local):
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   SMTP_USER=your@proton.me
#   SMTP_PASS=bridge_password_from_proton_app
#
# For standard SMTP (e.g. Gmail, Mailgun, Sendgrid, etc.):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# The "From" address shown in outgoing emails
SMTP_FROM=noreply@uszefaqualitet.pl

# ─── P24 / Przelewy24 (optional) ──────────────────────────────────────────────
P24_MERCHANT_ID=
P24_API_KEY=
